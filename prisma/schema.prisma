// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  password        String           // Hashed with bcrypt
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  projects        Project[]
  sales           Sale[]
  printerProfiles PrinterProfile[]
  sharedReports   SharedReport[]
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String
  data      String   // JSON string of the Project object
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales     Sale[]

  @@index([userId])
}

model Sale {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  projectName String
  tier        String   // competitive, standard, premium, luxury
  saleType    String   // wholesale, retail, custom, rush
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  notes       String?
  soldAt      DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([soldAt])
}

model PrinterProfile {
  id                        String   @id @default(cuid())
  userId                    String
  name                      String   // e.g. "My Bambu P1S"
  model                     String   // e.g. "Bambu Lab P1S"
  price                     Float    // Purchase price
  expectedLifespanYears     Float    // Years before replacement
  powerConsumptionWatts     Float    // Average power consumption
  failureRate               Float    // Failure rate percentage
  maintenanceCostPerHour    Float    // Maintenance cost per hour
  isDefault                 Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SharedReport {
  id          String    @id @default(cuid())
  userId      String?   // Optional - can be shared by guests too
  reportType  String    // "producer" or "invoice"
  projectData String    // JSON string of the project data
  pricingData String    // JSON string of the pricing result
  currency    String    @default("EUR")
  createdAt   DateTime  @default(now())
  expiresAt   DateTime? // Optional expiration

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
