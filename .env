# =============================================================================
# D-Calc Environment Variables
# =============================================================================

# --- Database (LOCAL: SQLite) ---
# This is the default for local development.
DATABASE_URL=file:/home/z/my-project/db/custom.db

# --- Database (PRODUCTION: Supabase PostgreSQL) ---
# For Vercel deployment, set these in the Vercel Dashboard → Settings → Environment Variables:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# The build script (vercel-build.sh) automatically switches the Prisma schema
# from SQLite to PostgreSQL when deploying to Vercel.

# --- Supabase ---
# Get these from: Supabase Dashboard → Project Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- NextAuth ---
NEXTAUTH_SECRET=calcfdm-secret-key-change-in-production-2024
# For local development:
NEXTAUTH_URL=http://localhost:3000
# For production on Vercel, set in Vercel Dashboard:
# NEXTAUTH_URL=https://your-app.vercel.app
