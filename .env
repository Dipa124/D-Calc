# =============================================================================
# D-Calc Environment Variables
# =============================================================================

# --- Database ---
# For LOCAL development (SQLite):
DATABASE_URL=file:/home/z/my-project/db/custom.db

# For PRODUCTION / Vercel (Supabase PostgreSQL):
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "pooled" connection for runtime.
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Supabase ---
# Get these from: Supabase Dashboard → Project Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- NextAuth ---
NEXTAUTH_SECRET=calcfdm-secret-key-change-in-production-2024
NEXTAUTH_URL=http://localhost:3000

# For production, set this to your Vercel URL
# NEXTAUTH_URL=https://your-app.vercel.app
